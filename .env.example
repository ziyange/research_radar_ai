# Research Radar AI local configuration
# Copy this file to .env and fill values locally. Do not commit real secrets.

APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8010
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database / infrastructure.
# Default developer mode uses in-memory storage and does not require Docker:
DATABASE_URL=sqlite+memory://dev
#
# To enable PostgreSQL/pgvector persistence, start docker-compose postgres and use:
# DATABASE_URL=postgresql+psycopg://research_radar:research_radar@localhost:5432/research_radar
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=research_radar
S3_SECRET_ACCESS_KEY=research_radar_password
S3_BUCKET=research-radar-dev

# AI provider. Keep AI_PROVIDER=mock until you add your own API key/model/base URL.
AI_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010/api/v1
