# Research Radar AI local configuration
# Copy this file to .env and fill values locally. Do not commit real secrets.

APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8010
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database / infrastructure.
# Default developer mode uses in-memory storage and does not require Docker:
DATABASE_URL=sqlite+memory://dev
#
# To enable PostgreSQL/pgvector persistence, start docker-compose postgres and use:
# DATABASE_URL=postgresql+psycopg://research_radar:research_radar@localhost:5432/research_radar
DEMO_SEED_ENABLED=false
DEV_USER_ID=usr_demo
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=research_radar
S3_SECRET_ACCESS_KEY=research_radar_password
S3_BUCKET=research-radar-dev

# AI provider. Use mock for local acceptance, or switch to openai for Aliyun Bailian compatible mode.
AI_PROVIDER=mock
OPENAI_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.6-plus
OPENAI_API_KEY=
AI_REQUEST_TIMEOUT_SECONDS=90
AGENT_AI_ANALYSIS_CONCURRENCY=2

# Agent source adapters.
# OpenAlex/Crossref are the default formal open metadata sources for Agent Scan.
# X-MOL/CNKI automatic search is disabled unless an official/authorized API or user export is provided.
# The app will not scrape X-MOL/CNKI public search pages, hook browser sessions, or store institution credentials.
OPENALEX_EMAIL=
AGENT_SOURCE_TIMEOUT_SECONDS=20
X_MOL_API_BASE_URL=
X_MOL_API_KEY=
CNKI_API_BASE_URL=
CNKI_API_KEY=

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010/api/v1
NEXT_PUBLIC_DEV_USER_ID=usr_demo
